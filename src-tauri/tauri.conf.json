{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Carimbo",
  "version": "1.0.0",
  "identifier": "br.com.arvoreconsultoria.carimbo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Carimbo",
        "url": "index.html",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false
      },
      {
        "label": "palette",
        "title": "Carimbo — Palette",
        "url": "palette.html",
        "width": 560,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": true
      },
      {
        "label": "radial",
        "title": "Carimbo — Choose",
        "url": "radial.html",
        "width": 420,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": true
      },
      {
        "label": "colorpicker",
        "title": "Carimbo — Color Picker",
        "url": "colorpicker.html",
        "width": 184,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "focus": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**", "$APPLOCALDATA/**", "$RESOURCE/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Árvore Consultoria",
    "category": "Productivity",
    "shortDescription": "Snippet manager and clipboard history toolbelt",
    "longDescription": "Carimbo keeps the text you use all the time — names, IDs, addresses, signatures — and inserts it into any app via a shortcut or a quick search. Includes clipboard history with search, pinning, and folders. English and Portuguese (Brazil) interface.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "PortugueseBR"]
      }
    }
  }
}
